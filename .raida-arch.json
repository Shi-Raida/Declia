{
  "version": "1.0",
  "language": "dart",
  "layers": {
    "entities": {
      "paths": ["lib/domain", "lib/core"],
      "allowedDependencies": [],
      "acceptedExternalPackages": ["freezed_annotation", "json_annotation"]
    },
    "usecases": {
      "paths": ["lib/usecases"],
      "allowedDependencies": ["entities"]
    },
    "adapters": {
      "paths": ["lib/presentation"],
      "allowedDependencies": ["usecases", "entities"]
    },
    "infrastructure": {
      "paths": ["lib/infrastructure", "lib/main.dart"],
      "allowedDependencies": ["adapters", "usecases", "entities"]
    }
  },
  "ignore": [
    "build",
    ".dart_tool",
    ".flutter-plugins",
    "**/*.g.dart",
    "**/*.freezed.dart",
    "**/*.mocks.dart",
    "**/*_test.dart",
    "**/test/**"
  ],
  "rules": {
    "maxFileLines": 300,
    "maxMethodsPerClass": 10,
    "maxComponentDistance": 0.2,
    "allowCircularDependencies": false
  },
  "ci": {
    "failOn": "high",
    "baselinePath": ".raida-arch-baseline.json"
  },
  "exceptions": [
    {
      "rule": "cross-layer-coupling",
      "files": ["lib/presentation/**/*.dart", "lib/infrastructure/di/injection.dart"],
      "imports": ["lib/usecases/**/params.dart"],
      "reason": "Params typedefs are simple value objects shared across layers by design"
    },
    {
      "rule": "dependency-rule",
      "files": ["lib/infrastructure/datasources/contract/*.dart"],
      "imports": ["lib/domain/**/*.dart"],
      "reason": "Data-source contracts live in infrastructure by design; domain does not reference them directly"
    }
  ]
}
